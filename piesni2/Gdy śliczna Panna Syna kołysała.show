["ba3f2a43517",{"name":"Gdy śliczna Panna Syna kołysała","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"ef5bba3f2a4","template":null},"timestamps":{"created":1777531325000,"modified":1777531325000,"used":null},"quickAccess":{},"meta":{"title":"Gdy śliczna Panna Syna kołysała","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"f5bba3f2a43":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Gdy śliczna Panna Syna kołysała,"}]},{"align":"","text":[{"style":"","value":"Z wielkim weselem, tak Jemu śpiewała:"}]},{"align":"","text":[{"style":"","value":"Li li li li laj, moje Dzieciąteczko"}]},{"align":"","text":[{"style":"","value":"li li li li laj, śliczne Paniąteczko."}]}]}],"globalGroup":"verse"},"5bba3f2a435":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wszystko stworzenie, śpiewaj Panu swemu,"}]},{"align":"","text":[{"style":"","value":"Pomóż radości wielkiej sercu memu."}]},{"align":"","text":[{"style":"","value":"Li li li li laj, wielki Królewiczu, li li li li laj, niebieski Dziedzicu!"}]}]}],"globalGroup":"verse"},"bba3f2a4351":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Sypcie się z nieba, liczni Aniołowie"}]},{"align":"","text":[{"style":"","value":"Śpiewajcie Panu, niebiescy duchowie:"}]},{"align":"","text":[{"style":"","value":"Li li li li laj, - mój wonny Kwiateczku, li li li li laj, w ubogim żłóbeczku."}]}]}],"globalGroup":"verse"}},"layouts":{"ef5bba3f2a4":{"name":"Domyślne","notes":"","slides":[{"id":"f5bba3f2a43"},{"id":"5bba3f2a435"},{"id":"bba3f2a4351"}]}},"media":{}}]