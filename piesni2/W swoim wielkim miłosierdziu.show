["eb548cf3629",{"name":"W swoim wielkim miłosierdziu","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"cf11d7eb548","template":null},"timestamps":{"created":1777531338000,"modified":1777531338000,"used":null},"quickAccess":{},"meta":{"title":"W swoim wielkim miłosierdziu","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"f11d7eb548c":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"W swoim wielkim miłosierdziu"}]},{"align":"","text":[{"style":"","value":"Bóg nas zrodził do nadziei"}]},{"align":"","text":[{"style":"","value":"W swoim wielkim miłosierdziu"}]},{"align":"","text":[{"style":"","value":"Bóg nas zrodził do nadziei,"}]},{"align":"","text":[{"style":"","value":"do wielkiej nadziei."}]}]}],"globalGroup":"chorus"},"11d7eb548cf":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Do Ciebie Panie, wznoszę duszę moją, racz mnie wysłuchać w łaskawości swojej. Moi wrogowie nie panują nade mną, bo kto Ci ufa, nie będzie zawstydzony."}]}]}],"globalGroup":"verse"},"1d7eb548cf3":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Daj mi poznać Twoje drogi Panie i naucz mnie chodzić Twoimi ścieżkami. Prowadź mnie w prawdzie według Twych pouczeń, Boże mój, Zbawco, w Tobie mam nadzieję."}]}]}],"globalGroup":"verse"},"d7eb548cf36":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wspomnij na swoje miłosierdzie, Panie, na swoją miłość, która trwa od wieków. Nie pamiętaj win i grzechów naszych, lecz o swoim wielkim miłosierdziu."}]}]}],"globalGroup":"verse"},"7eb548cf362":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Dobry jest Pan i łaskawy, wskazuje drogę grzesznikom. Pomaga pokornym czynić dobrze, uczy ubogich dróg swoich."}]}]}],"globalGroup":"verse"}},"layouts":{"cf11d7eb548":{"name":"Domyślne","notes":"","slides":[{"id":"f11d7eb548c"},{"id":"11d7eb548cf"},{"id":"1d7eb548cf3"},{"id":"d7eb548cf36"},{"id":"7eb548cf362"}]}},"media":{}}]