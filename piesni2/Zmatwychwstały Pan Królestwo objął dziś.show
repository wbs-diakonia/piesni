["aa504ec7b7f",{"name":"Zmatwychwstały Pan Królestwo objął dziś","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"7bd6baa504e","template":null},"timestamps":{"created":1777531340000,"modified":1777531340000,"used":null},"quickAccess":{},"meta":{"title":"Zmatwychwstały Pan Królestwo objął dziś","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"bd6baa504ec":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ref. Zmartwychwstały Pan "}]},{"align":"","text":[{"style":"","value":"królestwo objął dziś,"}]},{"align":"","text":[{"style":"","value":"Wszechmogący Wódz okazał swoją moc,"}]},{"align":"","text":[{"style":"","value":"Zakwitł krzyż i karmi, chroni mnie,"}]},{"align":"","text":[{"style":"","value":"Jezus Pan rozdaje życie swe."}]}]}],"globalGroup":"chorus"},"d6baa504ec7":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"1. Milczący Baranek, Baranek zabity"}]},{"align":"","text":[{"style":"","value":"Wybawił dziś nas z niewoli tego świata."}]},{"align":"","text":[{"style":"","value":"Hańbą okrył śmierć, nasza Pascha,"}]},{"align":"","text":[{"style":"","value":"On wywiódł dziś nas ze śmierci do życia."}]}]}],"globalGroup":"verse"},"6baa504ec7b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"2. W Ablu zabity, w Izaaku związany,"}]},{"align":"","text":[{"style":"","value":"Wzgardzony w Jakubie, w Józefie sprzedany,"}]},{"align":"","text":[{"style":"","value":"Zrodzony w Maryi, pięknej owieczki,"}]},{"align":"","text":[{"style":"","value":"Złożony w ofierze, powstaje dziś z martwych."}]}]}],"globalGroup":"verse"},"baa504ec7b7":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"3. Zstępuję z nieba do naszego cierpienia,"}]},{"align":"","text":[{"style":"","value":"By wyprowadzić nas z ciemności do światła."}]},{"align":"","text":[{"style":"","value":"Wzięty ze stada, zawieszony na drzewie,"}]},{"align":"","text":[{"style":"","value":"Naznacza nas Duchem i własną Krwią."}]}]}],"globalGroup":"verse"}},"layouts":{"7bd6baa504e":{"name":"Domyślne","notes":"","slides":[{"id":"bd6baa504ec"},{"id":"d6baa504ec7"},{"id":"6baa504ec7b"},{"id":"baa504ec7b7"}]}},"media":{}}]