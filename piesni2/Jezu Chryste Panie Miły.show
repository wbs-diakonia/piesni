["d78204e9301",{"name":"Jezu Chryste Panie Miły","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"052496d7820","template":null},"timestamps":{"created":1777531326000,"modified":1777531326000,"used":null},"quickAccess":{},"meta":{"title":"Jezu Chryste Panie Miły","author":"abc","artist":"","CCLI":"","copyright":""},"slides":{"52496d78204":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"1. Jezu Chryste, Panie miły "}]},{"align":"","text":[{"style":"","value":"Baranku bardzo cierpliwy!"}]},{"align":"","text":[{"style":"","value":"Wzniosłeś, wzniosłeś na krzyż ręce swoje,"}]},{"align":"","text":[{"style":"","value":"Gładząc, głądząc nieprawości moje."}]}]}],"globalGroup":"verse"},"2496d78204e":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"2. Płacz Go, człowiecze mizerny, "}]},{"align":"","text":[{"style":"","value":"Patrząc jak jest miłosierny;"}]},{"align":"","text":[{"style":"","value":"Jezus, Jezus na krzyżu umiera,"}]},{"align":"","text":[{"style":"","value":"Słońce, słońce jasność swą zawiera."}]}]}],"globalGroup":"verse"},"496d78204e9":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"3. Pan wyrzekł ostatnie słowa, "}]},{"align":"","text":[{"style":"","value":"Zwisła Mu na piersi głowa;"}]},{"align":"","text":[{"style":"","value":"Matka, Matka pod Nim frasobliwa,"}]},{"align":"","text":[{"style":"","value":"Stoi, stoi z żalu ledwie żywa."}]}]}],"globalGroup":"verse"},"96d78204e93":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"4. Zasłona się potargała, "}]},{"align":"","text":[{"style":"","value":"Ziemia rwie się, ryczy skała;"}]},{"align":"","text":[{"style":"","value":"Setnik woła: Syn to Boży!"}]},{"align":"","text":[{"style":"","value":"Tłuszcza wierząc w proch się korzy."}]}]}],"globalGroup":"verse"},"6d78204e930":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"5. Na koniec Mu bok przebito, "}]},{"align":"","text":[{"style":"","value":"Krew płynie z wodą obfito;"}]},{"align":"","text":[{"style":"","value":"Żal nasz, dziś wyznajem łzami:"}]},{"align":"","text":[{"style":"","value":"Jezu, zmiłuj się nad nami!"}]}]}],"globalGroup":"verse"}},"layouts":{"052496d7820":{"name":"Domyślne","notes":"","slides":[{"id":"52496d78204"},{"id":"2496d78204e"},{"id":"496d78204e9"},{"id":"96d78204e93"},{"id":"6d78204e930"}]}},"media":{}}]