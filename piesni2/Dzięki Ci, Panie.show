["c127ff9091b",{"name":"Dzięki Ci, Panie","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"1bf3377c127","template":null},"timestamps":{"created":1777531325000,"modified":1777531325000,"used":null},"quickAccess":{},"meta":{"title":"Dzięki Ci, Panie","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"bf3377c127f":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Dzięki Ci, Panie, za Ciało Twe i Krew"}]},{"align":"","text":[{"style":"","value":"Za dary nieskończone wielbimy Cię /x2"}]}]}],"globalGroup":"chorus"},"f3377c127ff":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Chwalimy Cię, Wszechmocny"}]},{"align":"","text":[{"style":"","value":"za dary Twe nieskończone"}]},{"align":"","text":[{"style":"","value":"Za Ciało i Twoją Krew"}]},{"align":"","text":[{"style":"","value":"Przebacz w swojej dobroci tym, co Ciebie niegodni"}]},{"align":"","text":[{"style":"","value":"Kiedy do Twego stołu się zbliżamy"}]}]}],"globalGroup":"verse"},"3377c127ff9":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Przebacz, żeś hojny i wierny"}]},{"align":"","text":[{"style":"","value":"Uwolnij z więzów grzechu"}]},{"align":"","text":[{"style":"","value":"Byśmy się odmienili"}]},{"align":"","text":[{"style":"","value":"Przez Tajemnice Najświętsze"}]}]}],"globalGroup":"verse"},"377c127ff90":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Niechaj przestworem spłynie zgwiazd Anioł Twój miły,"}]},{"align":"","text":[{"style":"","value":"Oczyści i uleczy nasze serca i ciała."}]},{"align":"","text":[{"style":"","value":"Powiedzie za sprawą tajemnicy na same szczyty nieba,"}]},{"align":"","text":[{"style":"","value":"A tu na ziemi ratuje obroną Twoją potężną."}]}]}],"globalGroup":"verse"},"77c127ff909":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Spojrzyj łaskawie, Stwórco na nas znikomych i słabych,"}]},{"align":"","text":[{"style":"","value":"Ocal, Doby Pasterzu, owce na swojej łące."}]},{"align":"","text":[{"style":"","value":"Tyś życie nam przywrócił wbrew nieprzyjacielowi,"}]},{"align":"","text":[{"style":"","value":"I wzmacniasz już na zawsze, siebie dając nam, Panie."}]}]}],"globalGroup":"verse"},"7c127ff9091":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Spraw to Ojcze Wszechmocny w dobroci swej niezmiernej,"}]},{"align":"","text":[{"style":"","value":"Byśmy się stali jedno,"}]},{"align":"","text":[{"style":"","value":"Z Tobą, Chrystusem i Duchem,"}]},{"align":"","text":[{"style":"","value":"Ty, coś w Trójcy jedyny."}]}]}],"globalGroup":"verse"}},"layouts":{"1bf3377c127":{"name":"Domyślne","notes":"","slides":[{"id":"bf3377c127f"},{"id":"f3377c127ff"},{"id":"bf3377c127f"},{"id":"3377c127ff9"},{"id":"bf3377c127f"},{"id":"377c127ff90"},{"id":"bf3377c127f"}]}},"media":{}}]