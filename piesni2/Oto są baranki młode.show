e."}]},{"align":"","text":[{"style":"","value":"Anioł mściciel z lękiem wziera,"}]},{"align":"","text":[{"style":"","value":"Pędzi morze rozdzielone,"}]},{"align":"","text":[{"style":"","value":"wrogów w nurtach swych pożera."}]}]}],"globalGroup":"verse"},"cb573e1082c":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Już nam Paschą Tyś, o Chryste,"}]},{"align":"","text":[{"style":"","value":"Wielkanocną też ofiarą,"}]},{"align":"","text":[{"style":"","value":"Tyś Przaśniki nasze czyste"}]},{"align":"","text":[{"style":"","value":"dla dusz prostych z szczerą wiarą."}]}]}],"globalGroup":"verse"},"b573e1082cc":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ofiaro niebios święta,Ty moc piekła pokonywasz,"}]},{"align":"","text":[{"style":"","value":"Zrywasz ciężkie śmierci pęta, wieniec życia nam zdobywasz."}]}]}],"globalGroup":"verse"},"573e1082cca":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Chrystus piekło pogromiwszy. Swój zwycięski znak roztacza,"}]},{"align":"","text":[{"style":"","value":"Niebo ludziom otworzywszy, króla mroków w więzy wtłacza."}]}]}],"globalGroup":"verse"},"73e1082cca3":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Byś nam wiecznie, Jezu drogi, Wielkanocną był radością,"}]},{"align":"","text":[{"style":"","value":"Strzeż od grzechu śmierci srogiej Odrodzonych Twą miłością."}]}]}],"globalGroup":"verse"},"3e1082cca3d":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value"