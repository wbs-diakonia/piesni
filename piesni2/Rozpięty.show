["c8df792421a",{"name":"Rozpięty","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"7317c8df792","template":null},"timestamps":{"created":1777531335000,"modified":1777531335000,"used":null},"quickAccess":{},"meta":{"title":"Rozpięty","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"317c8df7924":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Rozpięty na ramionach, jak sokół na niebie,"}]},{"align":"","text":[{"style":"","value":"Chrystusie, Synu Boga, spójrz proszę na ziemię,"}]}]}],"globalGroup":"chorus"},"17c8df79242":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Na ruchliwe ulice, zabieganych ludzi,"}]},{"align":"","text":[{"style":"","value":"gdy dzień się już kończy, a ranek się budzi."}]},{"align":"","text":[{"style":"","value":"Uśmiechnij się przyjaźnie z wysokiego krzyża"}]},{"align":"","text":[{"style":"","value":"do ciężko pracujących, którychh głód poniża."}]}]}],"globalGroup":"verse"},"7c8df792421":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Pociesz zrozpaczonych, chleba daj głodującym, "}]},{"align":"","text":[{"style":"","value":"modlących się wysłuchaj, pociesz umierających."}]},{"align":"","text":[{"style":"","value":"Spójrz, Cierpienia Sokole, na wszechświat, na ziemię,"}]},{"align":"","text":[{"style":"","value":"na cichy ciemny kościół, dziecko wzywające Ciebie."}]}]}],"globalGroup":"verse"}},"layouts":{"7317c8df792":{"name":"Domyślne","notes":"","slides":[{"id":"317c8df7924"},{"id":"17c8df79242"},{"id":"7c8df792421"}]}},"media":{}}]