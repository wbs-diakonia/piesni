["96fcd6e28e5",{"name":"W maleńkiej stajence, ubogiej stajence","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"1a2d96fcd6e","template":null},"timestamps":{"created":1777531338000,"modified":1777531338000,"used":null},"quickAccess":{},"meta":{"title":"W maleńkiej stajence, ubogiej stajence","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"a2d96fcd6e2":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"W maleńkiej stajence, ubogiej stajence, "}]},{"align":"","text":[{"style":"","value":"Ty leżysz w żłóbeczku, a wszyscy w podzięce,"}]},{"align":"","text":[{"style":"","value":"Przychodzą i składają Tobie dary,"}]},{"align":"","text":[{"style":"","value":"O Jezu przyjmij je."}]}]}],"globalGroup":"verse"},"2d96fcd6e28":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Maryja z Józefem stoją tuż obok,"}]},{"align":"","text":[{"style":"","value":"Pastuszki śpiewają, bydlęta klękają,"}]},{"align":"","text":[{"style":"","value":"A wszyscy wokoło głoszą tę radość,"}]},{"align":"","text":[{"style":"","value":"żeś narodził się."}]}]}],"globalGroup":"verse"},"d96fcd6e28e":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jak cudownie, że jesteś Panie,"}]},{"align":"","text":[{"style":"","value":"Bo przy Tobie nic złego się nie stanie,"}]},{"align":"","text":[{"style":"","value":"Dziękujemy, że się narodziłeś,"}]},{"align":"","text":[{"style":"","value":"Na naszej ziemi."}]}]}],"globalGroup":"verse"}},"layouts":{"1a2d96fcd6e":{"name":"Domyślne","notes":"","slides":[{"id":"a2d96fcd6e2"},{"id":"2d96fcd6e28"},{"id":"d96fcd6e28e"}]}},"media":{}}]