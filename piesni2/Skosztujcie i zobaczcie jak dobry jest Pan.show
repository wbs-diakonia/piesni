ć."}]}]}],"globalGroup":"verse"},"3cac22d4b7c":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Cieszcie się widokiem Jego, "}]},{"align":"","text":[{"style":"","value":"On was nie zawiedzie, "}]},{"align":"","text":[{"style":"","value":"Pan usłyszał głos biednego, "}]},{"align":"","text":[{"style":"","value":"wyrwał go z ucisków."}]}]}],"globalGroup":"verse"},"cac22d4b7c3":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Tych, co Pana się lękają,"}]},{"align":"","text":[{"style":"","value":" Anioł Pański broni, "}]},{"align":"","text":[{"style":"","value":"By ich wyrwać z ręki wroga, "}]},{"align":"","text":[{"style":"","value":"szańcem ich osłoni."}]}]}],"globalGroup":"verse"},"ac22d4b7c3b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Więc skosztujcie i zobaczcie, "}]},{"align":"","text":[{"style":"","value":"jaki Pan jest dobry! "}]},{"align":"","text":[{"style":"","value":"Kto do Niego się ucieknie, "}]},{"align":"","text":[{"style":"","value":"ten błogosławiony!"}]}]}],"globalGroup":"verse"}},"layouts":{"95dfd3cac22":{"name":"Domyślne","notes":"","slides":[{"id":"5dfd3cac22d"},{"id":"dfd3cac22d4"},{"id":"5dfd3cac22d"},{"id":"fd3cac22d4b"},{"id":"5dfd3cac22d"},{"id":"d3cac22d4b7"},{"id":"5dfd3cac22d"},{"id":"3cac22d4b7c"},{"id":"5dfd3cac22d"},{"id":"cac22d4b7c3"},{"id":"5dfd3cac22d"},{"id":"ac22d4b7c3b"}]}},"media":{}}]