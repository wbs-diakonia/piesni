["687b63b0f90",{"name":"Zbliżam się w pokorze","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"65b3938f687","template":null},"timestamps":{"created":1777531340000,"modified":1777531340000,"used":null},"quickAccess":{},"meta":{"title":"Zbliżam się w pokorze","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"5b3938f687b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Zbliżam się w pokorze - i niskości swej."}]},{"align":"","text":[{"style":"","value":"Wielbię Twój Majestat - skryty w Hostii tej"}]},{"align":"","text":[{"style":"","value":"Tobie dziś w ofierze - serce daję swe."}]},{"align":"","text":[{"style":"","value":"O, utwierdzaj w wierze - Jezu, dzieci Twe."}]}]}],"globalGroup":"verse"},"b3938f687b6":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Mylą się, o Boże - w Tobie wzrok i smak."}]},{"align":"","text":[{"style":"","value":"Kto się im poddaje - temu wiary brak."}]},{"align":"","text":[{"style":"","value":"Ja jedynie wierzyć - Twej nauce chcę,"}]},{"align":"","text":[{"style":"","value":"że w postaci Chleba - utaiłeś się."}]}]}],"globalGroup":"verse"},"3938f687b63":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Bóstwo swe na krzyżu - skryłeś wobec nas."}]},{"align":"","text":[{"style":"","value":"Tu ukryte z Bóstwem - Człowieczeństwo wraz."}]},{"align":"","text":[{"style":"","value":"Lecz w Oboje wierząc - wiem, że dojdę tam,"}]},{"align":"","text":[{"style":"","value":"gdzieś przygarnął łotra - do Twych niebios bram."}]}]}],"globalGroup":"verse"},"938f687b63b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jak niewierny Tomasz - Twych nie szukam ran,"}]},{"align":"","text":[{"style":"","value":"lecz wyznaję z wiarą - żeś mój Bóg i Pan."}]},{"align":"","text":[{"style":"","value":"Pomóż wierze mojej - Jezu łaską swą,"}]},{"align":"","text":[{"style":"","value":"ożyw mą nadzieję - rozpal miłość mą."}]}]}],"globalGroup":"verse"},"38f687b63b0":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ty, coś upamiętnił - śmierci Bożej czas,"}]},{"align":"","text":[{"style":"","value":"Chlebie Żywy, życiem - swym darzący nas."}]},{"align":"","text":[{"style":"","value":"Spraw, bym dla swej duszy - życie z Ciebie brał,"}]},{"align":"","text":[{"style":"","value":"bym nad wszelką słodycz - Ciebie poznać chciał."}]}]}],"globalGroup":"verse"},"8f687b63b0f":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ty, co jak pelikan - Krwią swą karmisz lud."}]},{"align":"","text":[{"style":"","value":"Przywróć mi niewinność - oddal grzechów brud."}]},{"align":"","text":[{"style":"","value":"Oczyść mnie Krwią Swoją - która wszystkich nas"}]},{"align":"","text":[{"style":"","value":"jedną kroplą może - obmyć z win i zmaz."}]}]}],"globalGroup":"verse"},"f687b63b0f9":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Pod zasłoną teraz - Jezu, widzę Cię,"}]},{"align":"","text":[{"style":"","value":"niech pragnienie serca - kiedyś spełni się,"}]},{"align":"","text":[{"style":"","value":"bym Oblicze Twoje - tam oglądać mógł,"}]},{"align":"","text":[{"style":"","value":"gdzie wybranym miejsce - przygotował Bóg."}]}]}],"globalGroup":"verse"}},"layouts":{"65b3938f687":{"name":"Domyślne","notes":""