","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Na wieki godzien jest"}]},{"align":"","text":[{"style":"","value":"Przyjąć chwałę, moc i cześć"}]},{"align":"","text":[{"style":"","value":"Ogłaszać chcę"}]},{"align":"","text":[{"style":"","value":"Jak wielki jest Bóg"}]}]}],"globalGroup":"chorus"}},"layouts":{"808c15d13f4":{"name":"Domyślne","notes":"","slides":[{"id":"08c15d13f4c"},{"id":"8c15d13f4c5"},{"id":"c15d13f4c53"},{"id":"15d13f4c533"}]}},"media":{}}]