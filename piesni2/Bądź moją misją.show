["57c3db4762b",{"name":"Bądź moją misją","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"c4757c3db47","template":null},"timestamps":{"created":1777531322000,"modified":1777531322000,"used":null},"quickAccess":{},"meta":{"title":"Bądź moją misją","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"4757c3db476":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Bądź moją misją, radością mą, "}]},{"align":"","text":[{"style":"","value":"nagrodą dla mnie Bóg."}]},{"align":"","text":[{"style":"","value":"Bądź mą mądrością, chcę słuchać jej,"}]},{"align":"","text":[{"style":"","value":"ma wartość w Tobie jest!"}]},{"align":"","text":[{"style":"","value":"bądź mym schronieniem, bądź siłą siłą mą,"}]},{"align":"","text":[{"style":"","value":"Odkupicielem mym, me serce w ciszy,"}]},{"align":"","text":[{"style":"","value":"wyznaje, że zaufać Tobie chce!"}]}]}],"globalGroup":"verse"},"757c3db4762":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Bądź wywyższony, bądź wywyższony, "}]},{"align":"","text":[{"style":"","value":"Jezu na wieki!"}]},{"align":"","text":[{"style":"","value":"Bądź wywyższony, na wieki!"}]},{"align":"","text":[{"style":"","value":"Bądź moją pasją, natchnieniem mym,"}]},{"align":"","text":[{"style":"","value":"chcę w pełni siebie dać, słów pustych koniec,"}]},{"align":"","text":[{"style":"","value":"uniżam się, chcę szczerym w Tobie być!"}]}]}],"globalGroup":"chorus"}},"layouts":{"c4757c3db47":{"name":"Domyślne","notes":"","slides":[{"id":"4757c3db476"},{"id":"757c3db4762"}]}},"media":{}}]