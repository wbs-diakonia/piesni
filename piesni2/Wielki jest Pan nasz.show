["787e1d2fb05",{"name":"Wielki jest Pan nasz","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"ab6787e1d2f","template":null},"timestamps":{"created":1777531338000,"modified":1777531338000,"used":null},"quickAccess":{},"meta":{"title":"Wielki jest Pan nasz","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"b6787e1d2fb":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wielki jest Pan nasz, godzien chwały i czci,"}]},{"align":"","text":[{"style":"","value":"A miasto Boga świętym miejscem jest,"}]},{"align":"","text":[{"style":"","value":"Radością ziemi Pan."}]},{"align":"","text":[{"style":"","value":"Wielki jest Pan i w nim zwycięstwo dane nam,"}]},{"align":"","text":[{"style":"","value":"On mocnym swym ramieniem wspiera nas,"}]},{"align":"","text":[{"style":"","value":"Kolana skłońmy swe."}]}]}],"globalGroup":"verse"},"6787e1d2fb0":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wywyższać chemy, Panie, Imię Twe"}]},{"align":"","text":[{"style":"","value":"I chcemy Ci dziękować"}]},{"align":"","text":[{"style":"","value":"Za Twą łaskę w naszym życiu."}]},{"align":"","text":[{"style":"","value":"W Tobie, Panie, pokładamy ufność swą,"}]},{"align":"","text":[{"style":"","value":"Jedynie Tyś wszechmogącym Bogiem,"}]},{"align":"","text":[{"style":"","value":"Tu na ziemi i na niebiosach."}]}]}],"globalGroup":"verse"}},"layouts":{"ab6787e1d2f":{"name":"Domyślne","notes":"","slides":[{"id":"b6787e1d2fb"},{"id":"6787e1d2fb0"}]}},"media":{}}]