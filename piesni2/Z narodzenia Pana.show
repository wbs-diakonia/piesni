["02aa50b19ae",{"name":"Z narodzenia Pana","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"13e802aa50b","template":null},"timestamps":{"created":1777531339000,"modified":1777531339000,"used":null},"quickAccess":{},"meta":{"title":"Z narodzenia Pana","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"3e802aa50b1":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Z narodzenia Pana dzień dziś wesoły,"}]},{"align":"","text":[{"style":"","value":"Wyśpiewują chwałę Bogu żywioły!"}]},{"align":"","text":[{"style":"","value":"Radość ludzi wszędy słynie,"}]},{"align":"","text":[{"style":"","value":"Anioł budzi przy dolinie"}]},{"align":"","text":[{"style":"","value":"Pasterzy, co paśli pod borem woły!"}]}]}],"globalGroup":"verse"},"e802aa50b19":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wypada wśród nocy ogień z obłoku!"}]},{"align":"","text":[{"style":"","value":"Dumają pasterze w takim widoku."}]},{"align":"","text":[{"style":"","value":"Każdy pyta, co się dzieje,"}]},{"align":"","text":[{"style":"","value":"Czy nie świta, czy nie dnieje,"}]},{"align":"","text":[{"style":"","value":"Skąd ta łuna bije, tak miła oku?"}]}]}],"globalGroup":"verse"},"802aa50b19a":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ale gdy anielskie głosy słyszeli,"}]},{"align":"","text":[{"style":"","value":"Zaraz do Betlejem prosto bieżeli."}]},{"align":"","text":[{"style":"","value":"Tam witali w żłobie Pana,"}]},{"align":"","text":[{"style":"","value":"Poklękali na kolana"}]},{"align":"","text":[{"style":"","value":"I oddali dary, co z sobą wzięli."}]}]}],"globalGroup":"verse"}},"layouts":{"13e802aa5