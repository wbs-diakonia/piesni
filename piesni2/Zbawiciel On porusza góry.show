["8aceec065b3",{"name":"Zbawiciel On porusza góry","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"bb4088aceec","template":null},"timestamps":{"created":1777531340000,"modified":1777531340000,"used":null},"quickAccess":{},"meta":{"title":"Zbawiciel On porusza góry","author":"DS","artist":"","CCLI":"","copyright":""},"slides":{"b4088aceec0":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jesteśmy Twymi dziećmi, potrzebujemy Ciebie,"}]},{"align":"","text":[{"style":"","value":"miłości, która trwa."}]},{"align":"","text":[{"style":"","value":"Dobroci nieskończonej, łaski i nadziei,"}]},{"align":"","text":[{"style":"","value":"na wybawienie"}]}]}],"globalGroup":"verse"},"4088aceec06":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ref. Zbawiciel, On porusza góry,"}]},{"align":"","text":[{"style":"","value":"On może wybawić mnie, może wybawić mnie."}]},{"align":"","text":[{"style":"","value":"Na zawsze sprawca odkupienia,"}]},{"align":"","text":[{"style":"","value":"zmartwychwstał, pokonał śmierć, Jezus pokonał śmierć"}]}]}],"globalGroup":"chorus"},"088aceec065":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Weź mnie jakim jestem, z mym grzechem i mym lękiem."}]},{"align":"","text":[{"style":"","value":"wypełnij życie me."}]},{"align":"","text":[{"style":"","value":"Tobie się oddaję, całą moją wiarę"}]},{"align":"","text":[{"style":"","value":"oddaję Tobie."}]}]}],"globalGroup":"verse"},"88aceec065b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Chcę być światłem, aby p