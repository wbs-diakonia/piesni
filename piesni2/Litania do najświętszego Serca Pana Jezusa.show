e":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Serce Jezusa, aż do śmierci posłuszne,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, wlócznią przebyte,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, źrodło wszelkiej pociechy,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, życie i zmartwychwstanie nasze,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, pokoju i pojednanie nasze,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, krwawa ofiaro grzeszników"}]}]}],"globalGroup":"verse"},"17031573d12":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Serce Jezusa, zbawienie ufających Tobie,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa, nadziejo w Tobie umierających,"}]},{"align":"","text":[{"style":"","value":"Serce Jezusa rozkoszy wszystkich Świętych,"}]}]}],"globalGroup":"verse"},"7031573d12c":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Baranku Boży, który gładzisz grzechy świata, "}]},{"align":"","text":[{"style":"","value":"przepuść nam, Panie."}]},{"align":"","text":[{"style":"","value":"Baranku Boży, który gładzisz grzechy świata,"}]},{"align":"","text":[{"style":"","value":"wysłuchaj nas, Panie."}]},{"align":"","text":[{"style":"","value":"Baranku Boży, który gładzisz grzechy świata,"}]},{"align":"","text":[{"style":"","value":"zmiłuj się nad nami."}]}]}],"globalGroup":"verse"},"031573d12ca":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"K. Jezu cichy i pokornego serca."}]},{"align":"","text":[{"style":"","value":"W. Uczyń serca nasze według Serca Twego."}]}]}],"globalGroup":"verse"},"31573d12ca3":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Do Serca Twojego uciekamy się Jezu, Boski Zbawicielu! Naszymi grzechami racz się nie zrażać, o Panie święty! Ale od wszelakich złych czynów racz nas zawsze zachować, Boże łaskawy i najlitościwszy! O Jezu dobry, Zbawicielu słodki, Pośredniku Boski, jedyna ucieczko nasza! W sercu Twoim racz nas obmyć, do Serca Twojego racz nas przytulić, w Twym Sercu na wieki racz nas zachować."}]}]}],"globalGroup":"verse"}},"layouts":{"69fa98e1703":{"name":"Domyślne","notes":"","slides":[{"id":"9fa98e17031"},{"id":"fa98e170315"},{"id":"a98e1703157"},{"id":"98e17031573"},{"id":"8e17031573d"},{"id":"e17031573d1"},{"id":"17031573d12"},{"id":"7031573d12c"},{"id":"031573d12ca"},{"id":"31573d12ca3"}]}},"media":{}}]