["db05671303c",{"name":"Maryjo, Matko mojego wezwania","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"012cdb05671","template":null},"timestamps":{"created":1777531329000,"modified":1777531329000,"used":null},"quickAccess":{},"meta":{"title":"Maryjo, Matko mojego wezwania","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"12cdb056713":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Maryjo, Matko mojego wezwania"}]},{"align":"","text":[{"style":"","value":"Chcę i pragnę, idąc za Twym słowem"}]},{"align":"","text":[{"style":"","value":"Czynić wszystko, co powie mi Jezus,"}]},{"align":"","text":[{"style":"","value":"Miłować Jego wolę"}]},{"align":"","text":[{"style":"","value":"A wszystko inne ze względu na Niego samego"}]}]}],"globalGroup":"verse"},"2cdb0567130":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Bo tak jest z tymi, którzy z Ducha "}]},{"align":"","text":[{"style":"","value":"narodzili się,"}]},{"align":"","text":[{"style":"","value":"Nikt nie wie, dokąd pójdą"}]},{"align":"","text":[{"style":"","value":"za wolą Twą"}]}]}],"globalGroup":"chorus"},"cdb05671303":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Słuchać słowa całym sercem,"}]},{"align":"","text":[{"style":"","value":"I w Duchu Świętym je wypełniać"}]},{"align":"","text":[{"style":"","value":"Amen, amen, amen! /x2"}]}]}],"globalGroup":"verse"}},"layouts":{"012cdb05671":{"name":"Domyślne","notes":"","slides":[{"id":"12cdb056713"},{"id":"2cdb0567130"},{"id":"cdb05671303"}]}},"media":{}}]