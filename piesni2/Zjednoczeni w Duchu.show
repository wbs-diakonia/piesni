["6eea3ec7bd6",{"name":"Zjednoczeni w Duchu","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"59bc56eea3e","template":null},"timestamps":{"created":1777531340000,"modified":1777531340000,"used":null},"quickAccess":{},"meta":{"title":"Zjednoczeni w Duchu","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"9bc56eea3ec":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"1. Zjednoczeni w Duchu, zjednoczeni w Nim, /2x"}]},{"align":"","text":[{"style":"","value":"Módlmy się, aby jedność była odnowiona w nas,"}]},{"align":"","text":[{"style":"","value":"Aby świat cały poznał uczniów Chrystusa w nas,"}]},{"align":"","text":[{"style":"","value":"Aby świat cały ujrzał miłość w nas."}]}]}],"globalGroup":"verse"},"bc56eea3ec7":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"2.Wraz z innymi pójdziemy, podaj mi swoją dłoń, /2x"}]},{"align":"","text":[{"style":"","value":"Wszystkim głosić będziemy tę radosną dla nas wieść,"}]},{"align":"","text":[{"style":"","value":"Że nasz Pan kroczy z nami, że nasz Pan z nami jest,"}]},{"align":"","text":[{"style":"","value":"Że nasz Pan zawsze z nami wszędzie jest."}]}]}],"globalGroup":"verse"},"c56eea3ec7b":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"3.Chcemy razem pracować, chcemy złączyć swój trud, /2x"}]},{"align":"","text":[{"style":"","value":"By nie stracić godności, którą Pan obdarzył nas,"}]},{"align":"","text":[{"style":"","value":"Aby strzec ludzkiej dumy, aby strzec dumy swej,"}]},{"align":"","text":[{"style":"","value":"Żeby człowiek zachował godność swą."}]}]}],"globalGroup":"verse"},"56eea3ec7bd":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"4.Niechaj chwała brzmi Ojcu, który stworzył ten świat, /2x"}]},{"align":"","text":[{"style":"","value":"Chwała też Chrystusowi, który Synem Jego jest"}]},{"align":"","text":[{"style":"","value":"I Duchowi też chwała, który jednoczy nas,"}]},{"align":"","text":[{"style":"","value":"I Duchowi też, który łączy nas."}]}]}],"globalGroup":"verse"}},"layouts":{"59bc56eea3e":{"name":"Domyślne","notes":"","slides":[{"id":"9bc56eea3ec"},{"id":"bc56eea3ec7"},{"id":"c56eea3ec7b"},{"id":"56eea3ec7bd"}]}},"media":{}}]