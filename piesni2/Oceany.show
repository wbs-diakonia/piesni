["fea506fd050",{"name":"Oceany","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"a2302dfea50","template":null},"timestamps":{"created":1777531331000,"modified":1777531331000,"used":null},"quickAccess":{},"meta":{"title":"Oceany","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"2302dfea506":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Znad oceanów do mnie wołasz, "}]},{"align":"","text":[{"style":"","value":"gdzie każdy krok niepewny jest."}]},{"align":"","text":[{"style":"","value":"Ty jesteś tam, gdzie niewiadoma,"}]},{"align":"","text":[{"style":"","value":"tam znajdę grunt dla wiary mej."}]}]}],"globalGroup":"verse"},"302dfea506f":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"I będę wzywać imię Twe,"}]},{"align":"","text":[{"style":"","value":"i ponad fale patrzeć chcę, gdy burzą się,"}]},{"align":"","text":[{"style":"","value":"mej duszy pokój w Tobie jest,"}]},{"align":"","text":[{"style":"","value":"gdzie pójdziesz Ty, ja pójdę też"}]}]}],"globalGroup":"chorus"},"02dfea506fd":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Mój strach utonie w Twojej łasce,"}]},{"align":"","text":[{"style":"","value":"bo ręka Twa, prowadzi mnie."}]},{"align":"","text":[{"style":"","value":"I Ty mnie nigdy nie zawiodłeś,"}]},{"align":"","text":[{"style":"","value":"wiem teraz też nie zawiedziesz mnie."}]}]}],"globalGroup":"verse"},"2dfea506fd0":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"I będę wzywać imię Twe,"}]},{"align":"","text":[{"style":"","value":"i ponad fale patrzeć chcę, gdy burzą się, mej duszy pokój w Tobie jest,"}]},{"align":"","text":[{"style":"","value":"gdzie pójdziesz Ty, ja pójdę też."}]}]}],"globalGroup":"chorus"},"dfea506fd05":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Duchu prowadź mnie, gdzie wiara nie ma granic,"}]},{"align":"","text":[{"style":"","value":"Daj mi chodzić nad wodami, gdziekolwiek mnie zabierzesz."}]},{"align":"","text":[{"style":"","value":"Prowadź głębiej niż pójść mogą moje stopy,"}]},{"align":"","text":[{"style":"","value":"moja wiara się umocni, w Twej obecności, Boże. /4x"}]}]}],"globalGroup":"verse"}},"layouts":{"a2302dfea50":{"name":"Domyślne","notes":"","slides":[{"id":"2302dfea506"},{"id":"302dfea506f"},{"id":"02dfea506fd"},{"id":"2dfea506fd0"},{"id":"dfea506fd05"}]}},"media":{}}]