["629938c93eb",{"name":"W Tobie jestem wolny","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"8cf3629938c","template":null},"timestamps":{"created":1777531338000,"modified":1777531338000,"used":null},"quickAccess":{},"meta":{"title":"W Tobie jestem wolny","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"cf3629938c9":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Zabrałeś cały strach, otarłeś moje łzy"}]},{"align":"","text":[{"style":"","value":"W Tobie jestem wolny, w Tobie jestem wolny!"}]},{"align":"","text":[{"style":"","value":"Zabrałeś cały strach, otarłeś moje łzy,"}]},{"align":"","text":[{"style":"","value":"W Tobie jestem wolnym w Tobie jestem wolny!"}]}]}],"globalGroup":"verse"},"f3629938c93":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Bo Ty skradłeś moje serce, "}]},{"align":"","text":[{"style":"","value":"nie potrzebuje już niczego więcej"}]},{"align":"","text":[{"style":"","value":"Tylko Ciebie, Jezu! /x2"}]}]}],"globalGroup":"chorus"},"3629938c93e":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Dziś na skale postawiona, jak młody orzeł wzbijam się."}]},{"align":"","text":[{"style":"","value":"Twoją łaską przytulona, mówię twierdzą moją,"}]},{"align":"","text":[{"style":"","value":"skałą moją, ucieczką moją jesteś,"}]},{"align":"","text":[{"style":"","value":"Święty Jahwe, kochany Tato! Tatusiu!"}]}]}],"globalGroup":"verse"}},"layouts":{"8cf3629938c":{"name":"Domyślne","notes":"","slides":[{"id":"cf3629938c9"},{"id":"f3629938c93"},{"id":"3629938c93e"}]}},"media":{}}]