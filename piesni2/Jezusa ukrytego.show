["06234e80e71",{"name":"Jezusa ukrytego","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"3b306234e80","template":null},"timestamps":{"created":1777531327000,"modified":1777531327000,"used":null},"quickAccess":{},"meta":{"title":"Jezusa ukrytego","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"b306234e80e":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jezusa ukrytego mam w Sakramencie czcić,"}]},{"align":"","text":[{"style":"","value":"Wszystko oddać dla Niego, Jego miłością żyć!"}]},{"align":"","text":[{"style":"","value":"On się nam daje cały, z nami zamieszkał tu."}]},{"align":"","text":[{"style":"","value":"Dla Jego Boskiej chwały życie poświęćmy Mu!"}]},{"align":"","text":[{"style":"","value":"Wiarą ukorzyć trzeba zmysły i rozum swój,"}]},{"align":"","text":[{"style":"","value":"Bo tu już nie ma chleba, To Bóg, to Jezus mój!"}]}]}],"globalGroup":"verse"},"306234e80e7":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Tu Mu ciągle Hosanna! śpiewa anielski chór"}]},{"align":"","text":[{"style":"","value":"A ta cześć nieustanna, to dla nas biednych wzór."}]},{"align":"","text":[{"style":"","value":"Dzielić z nami wygnanie, Jego rozkosze są,"}]},{"align":"","text":[{"style":"","value":"Niechże z Nim przebywanie będzie radością mą!"}]},{"align":"","text":[{"style":"","value":"On wie co udręczenie, On zna, co smutku łzy."}]},{"align":"","text":[{"style":"","value":"Powiem Mu swe cierpienie, bo serce z bólu drży"}]}]}],"globalGroup":"verse"}},"layouts":{"3b306234e80":{"name":"Domyślne","notes":"","slides":[{"id":"b306234e80e"},{"id":"306234e80e7"}]}},"media":{}}]