["1549517dd0f",{"name":"jak to jest że jesteś","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"c511549517d","template":null},"timestamps":{"created":1777531329000,"modified":1777531329000,"used":null},"quickAccess":{},"meta":{"title":"jak to jest że jesteś","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"511549517dd":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Miłość Twoja nad górami - Ponad szczyty wznosi się. "}]},{"align":"","text":[{"style":"","value":"Jak to jest, że Jesteś /x3"}]},{"align":"","text":[{"style":"","value":"Z nami i w niebie nie brakuje Cię?"}]},{"align":"","text":[{"style":"","value":"Panie jeśli zechcesz - Przyjąć mnie takim - jakim jestem,"}]},{"align":"","text":[{"style":"","value":"Jestem gotowy już dziś"}]}]}],"globalGroup":"verse"},"11549517dd0":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jeśli rozkażesz, odrzucę wszystko, co nie z Ciebie "}]},{"align":"","text":[{"style":"","value":"By za Tobą w prawdzie /x3 iść."}]},{"align":"","text":[{"style":"","value":"Bo z Tobą Panie i przez Ciebie"}]},{"align":"","text":[{"style":"","value":"Wszystko, wszystko dzieje się."}]},{"align":"","text":[{"style":"","value":"Także życie moje - niech w Twoim trwa Imieniu."}]},{"align":"","text":[{"style":"","value":"Ty mi pozwoliłeś /x3 - Na nowo narodzić się."}]}]}],"globalGroup":"verse"}},"layouts":{"c511549517d":{"name":"Domyślne","notes":"","slides":[{"id":"511549517dd"},{"id":"11549517dd0"}]}},"media":{}}]