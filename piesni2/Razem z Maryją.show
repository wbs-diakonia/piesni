["6826f2d6fac",{"name":"Razem z Maryją","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"39d306826f2","template":null},"timestamps":{"created":1777531335000,"modified":1777531335000,"used":null},"quickAccess":{},"meta":{"title":"Razem z Maryją","author":"abc","artist":"","CCLI":"","copyright":""},"slides":{"9d306826f2d":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"1.Kiedy przechodzi taka pełna blasku,"}]},{"align":"","text":[{"style":"","value":"To aniołowie patrzą zachwyceni,"}]},{"align":"","text":[{"style":"","value":"Umiłowana Córka Boga Ojca,"}]},{"align":"","text":[{"style":"","value":"Kwiat najpiękniejszy całego stworzenia."}]},{"align":"","text":[{"style":"","value":"Mistrzyni życia w świętej codzienności,"}]},{"align":"","text":[{"style":"","value":"Znała ból straty i smutek rozstania,"}]},{"align":"","text":[{"style":"","value":"Nawet pod krzyżem nie przestała kochać,"}]},{"align":"","text":[{"style":"","value":"Nawet pod krzyżem ufała bez granic."}]}]}],"globalGroup":"verse"},"d306826f2d6":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Idąc z Maryją nie pomylisz drogi, "}]},{"align":"","text":[{"style":"","value":"modląc się do Niej nie stracisz nadziei,"}]},{"align":"","text":[{"style":"","value":"gdy ją zawołasz rozproszy Twą rozpacz,"}]},{"align":"","text":[{"style":"","value":"myślą bądź przy Niej a wtedy nie zginiesz."}]},{"align":"","text":[{"style":"","value":"Gdy Ona strzeże nie musisz się lękać,"}]},{"align":"","text":[{"style":"","value":"gdy Cię prowadzi nie czujesz zmęczenia,"}]},{"align":"","text":[{"style":"","value":"w jej obecności matczynej, łaskawej,"}]},{"align":"","text":[{"style":"","value":"bezpiecznie dotrzesz do portu zbawienia."}]}]}],"globalGroup":"chorus"},"3