["ae707f4f11f",{"name":"Kiedy ranne wstają zorze","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"6c7f1cae707","template":null},"timestamps":{"created":1777531327000,"modified":1777531327000,"used":null},"quickAccess":{},"meta":{"title":"Kiedy ranne wstają zorze","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"c7f1cae707f":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Kiedy ranne wstają zorze, Tobie ziemia, Tobie morze,"}]},{"align":"","text":[{"style":"","value":"Tobie śpiewa żywioł wszelki,bądź pochwalon, Boże wielki!"}]}]}],"globalGroup":"verse"},"7f1cae707f4":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"A człowiek, który bez miary, obsypany Twymi dary,"}]},{"align":"","text":[{"style":"","value":"Coś go stworzył i oca1ił, a czemuż by Cię nie chwalił.?"}]}]}],"globalGroup":"verse"},"f1cae707f4f":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Ledwie oczy przetrzeć zdołam, wnet do mego Pana wołam,"}]},{"align":"","text":[{"style":"","value":"Do mego Boga na niebie, i szukam Go wkoło siebie."}]}]}],"globalGroup":"verse"},"1cae707f4f1":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Wielu snem śmierci upadli, co się wczoraj spać pokładli,"}]},{"align":"","text":[{"style":"","value":"My się jeszcze obudzili, byśmy Cię, Boże chwalili."}]}]}],"globalGroup":"verse"},"cae707f4f11":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Boże w Trójcy niepojęty, Ojcze, Synu, Duchu Święty"}]},{"align":"","text":[{"style":"","value":"Tobie chwałę oddajemy, niech dla Ciebie dziś żyjemy"}]}]}],"globalGroup":"verse"}},"layouts":{"6c7f1cae707":{"name":"Domyślne","notes":"","slides":[{"id":"c7f1cae707f"},{"id":"7f1cae707f4"},{"id":"f1cae707f4f"},{"id":"1cae707f4f1"},{"id":"cae707f4f11"}]}},"media":{}}]