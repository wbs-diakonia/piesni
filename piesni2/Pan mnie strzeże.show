["eb8836e6767",{"name":"Pan mnie strzeże","origin":"openlyrics","private":false,"category":"song","settings":{"activeLayout":"a19cfeeb883","template":null},"timestamps":{"created":1777531332000,"modified":1777531332000,"used":null},"quickAccess":{},"meta":{"title":"Pan mnie strzeże","author":"a","artist":"","CCLI":"","copyright":""},"slides":{"19cfeeb8836":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Pan mnie strzeże, Pan mnie strzeże"}]},{"align":"","text":[{"style":"","value":"Czuwa nade mną Bóg, On jest moim cieniem"}]}]}],"globalGroup":"chorus"},"9cfeeb8836e":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Chcę z Tobą chodzić po wszystkich mych drogach,"}]},{"align":"","text":[{"style":"","value":"Prowadź mnie w mocy Swej, abym nie upadł!"}]}]}],"globalGroup":"verse"},"cfeeb8836e6":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Biegnę do Ciebie, aby być z Tobą,"}]},{"align":"","text":[{"style":"","value":"Chce Ciebie widzieć, aby być sobą!"}]}]}],"globalGroup":"verse"},"feeb8836e67":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Jak Henoch, Panie z Tobą chodzić chciał, tak z Tobą chodzić chcę,"}]},{"align":"","text":[{"style":"","value":"Jak Paweł wszystkie kroki Tobie dał, tak ja oddaję kroki swe!"}]}]}],"globalGroup":"verse"},"eeb8836e676":{"group":"","color":null,"settings":{},"notes":"","items":[{"style":"top:88px;left:50px;height:904px;width:1820px;","lines":[{"align":"","text":[{"style":"","value":"Nie boję się, wchodzę w noc ciemną bez lęku,"}]},{"align":"","text":[{"style":"","value":"D