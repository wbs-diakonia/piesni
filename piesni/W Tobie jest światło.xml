<?xml version='1.0' encoding='UTF-8'?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2025-09-27T17:38:58">
  <properties>
    <titles>
      <title>W Tobie jest światło</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>W Tobie jest światło, <br/>każdy mrok rozjaśni.	<br/>W Tobie jest życie, <br/>ono śmierć zwycięża.<br/>Ufam Tobie, <br/>Miłosierny <br/>Jezu, Wybaw nas.</lines>
    </verse>
  </lyrics>
</song>
