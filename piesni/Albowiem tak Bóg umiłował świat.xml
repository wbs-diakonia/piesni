<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2026-04-26T08:37:49">
  <properties>
    <titles>
      <title>Albowiem tak Bóg umiłował świat</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Albowiem tak Bóg umiłował świat<br/>że Syna Jednorodzonego dał, <br/>Nie zginął, lecz życie wieczne miał<br/>by mógł żyć na wieki,<br/>by mógł żyć na wieki.</lines>
    </verse>
  </lyrics>
</song>
