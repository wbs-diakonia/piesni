  <properties>
    <titles>
      <title>Każdego dnia</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Każdego dnia przy Tobie trwać,<br/>Poznawać Ciebie<br/><br/>Pragnę bliżej Ciebie być /x2<br/><br/>Jeszcze bardziej kochać Cię,<br/>Jeszcze dłużej wielbić Cię,<br/>Rozkochać się</lines>
    </verse>
  </lyrics>
</song>
