<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:37">
  <properties>
    <titles>
      <title>Będę Cię wysławiał Panie</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Będę Cię wysławiał Panie,<br/>całym sercem swoim.<br/>Będę opowiadał wszystkim cuda Twoje.<br/>Będę się radował i weselił w Tobie.<br/>Będę opiewał Imię Twoje.</lines>
    </verse>
  </lyrics>
</song>
