<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2026-04-26T07:18:41">
  <properties>
    <titles>
      <title>Ukaż mi Panie swą Twarz</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ukaż mi Panie Swą Twarz,<br/>Daj mi usłyszeć Twój głos,<br/>Bo słodki jest Twój głos<br/>I twarz pełna wdzięku<br/>Ukaż mi Panie Swą Twarz.</lines>
    </verse>
  </lyrics>
</song>
