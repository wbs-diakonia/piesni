<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2026-03-09T18:49:14">
  <properties>
    <titles>
      <title>Tylko w cieniu krzyża</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Tylko w cieniu krzyża, jak krzew różany<br/>Pragnę wzrastać, z niego czerpać życie<br/><br/><br/>Wypełnij mnie barwą Twej Krwi, Panie<br/>Pokrop czerwienią Twego miłosierdzia</lines>
    </verse>
  </lyrics>
</song>
