  <properties>
    <titles>
      <title>Będę śpiewał Tobie</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Będę śpiewał Tobie, Mocy moja!<br/>Ty, Panie jesteś mą nadzieją.<br/>Tobie ufam i bać się nie będę</lines>
    </verse>
  </lyrics>
