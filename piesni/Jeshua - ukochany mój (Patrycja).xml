  <lyrics>
    <verse name="v1">
      <lines>Jeshua, Jeshua<br/><br/>Ukochany mój najpiękniejszy jest<br/>Wśród tysiąca, tysięcy...<br/><br/>Bo twe jest królestwo, Twa jest potęga,<br/>Twoja jest chwała, Na wieki amen.</lines>
