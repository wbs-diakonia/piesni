    <titles>
      <title>Nic nie musisz mówić nic</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Nic, nie musisz mówić nic, <br/>odpocznij we Mnie,<br/>czuj się bezpiecznie.<br/><br/>Pozwól kochać się,<br/>Miłość pragnie Ciebie.</lines>
    </verse>
  </lyrics>
