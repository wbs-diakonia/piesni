  <properties>
    <titles>
      <title>Panie Twój tron</title>
      <title>wywyższamy Cię</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Panie, Twój tron wznosi się nad wszystkie ziemie świata. <br/>Jesteś Najwyższy, Panie mój, Królu mój. <br/><br/>Wywyższamy Cię, wywyższamy Cię, <br/>Wywyższamy Cię, Boże nasz.</lines>
    </verse>
  </lyrics>
</song>
