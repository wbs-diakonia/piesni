<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:37">
  <properties>
    <titles>
      <title>Boże mój, Boże</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Boże mój, Boże szukam Ciebie<br/>I pragnie Ciebie moja dusza<br/>Ciało moje tęskni za Tobą <br/>Jak ziemia łaknąca wody</lines>
    </verse>
  </lyrics>
</song>
