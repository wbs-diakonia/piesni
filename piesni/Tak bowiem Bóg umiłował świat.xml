  <properties>
    <titles>
      <title>Tak bowiem Bóg umiłował świat</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Tak bowiem Bóg umiłował świat,<br/>że Syna swego nam dał,<br/>aby każdy, kto w Niego wierzy<br/>miał życie wieczne,<br/>miał życie wieczne.</lines>
    </verse>
  </lyrics>
</song>
