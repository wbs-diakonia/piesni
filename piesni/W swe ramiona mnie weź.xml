  <properties>
    <titles>
      <title>W swe ramiona mnie weź</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>W swe ramiona mnie weź <br/>Mocą krzyża dodaj sił <br/>W księgę życia wpisz mnie <br/>Do swej chwały przyjąć chciej</lines>
    </verse>
  </lyrics>
