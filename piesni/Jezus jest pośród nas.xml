<?xml version='1.0' encoding='UTF-8'?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:41">
  <properties>
    <titles>
      <title>Jezus jest pośród nas</title>
      <title>znów dotknij serc</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Jezus jest pośród nas, <br/>obecny tu w Duchu swym,<br/>wszystkich nas wzywa zbliżcie się! <br/>Znów dotknij serc nasz Panie,<br/>napełń nas swym Duchem. <br/>Dotknij serc nasz Panie napełń nas.</lines>
    </verse>
  </lyrics>
</song>
