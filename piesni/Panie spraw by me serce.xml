  <properties>
    <titles>
      <title>Panie spraw by me serce</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Panie spraw, by me serce<br/>Stało się sercem Twoim<br/>Bym był cichy i pokorny jak Ty<br/>Abym znalazł ukojenie dla duszy mojej</lines>
    </verse>
  </lyrics>
