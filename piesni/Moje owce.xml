  <properties>
    <titles>
      <title>Moje owce</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Moje owce słuchają głosu mego, <br/>a ja je znam.<br/>Idą one za mną, a ja <br/>życie wieczne daje im.<br/> <br/>Nie zginą one na wieki /x4<br/>I nikt nie wyrwie ich z ręki mej.</lines>
    </verse>
  </lyrics>
</song>
