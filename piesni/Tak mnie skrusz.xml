  <properties>
    <titles>
      <title>Tak mnie skrusz</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Tak mnie skrusz, tak mnie złam,<br/>Tak mnie wypal Panie,<br/>Byś został tylko Ty<br/>Byś został tylko Ty<br/>Panie mój</lines>
    </verse>
  </lyrics>
