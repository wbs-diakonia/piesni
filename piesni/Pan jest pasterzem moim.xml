  <properties>
    <titles>
      <title>Pan jest pasterzem moim</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Pan jest Pasterzem moim<br/>Niczego mi nie braknie<br/>Na niwach zielonych pasie mnie<br/>Nad wody spokojne prowadzi mnie</lines>
    </verse>
  </lyrics>
