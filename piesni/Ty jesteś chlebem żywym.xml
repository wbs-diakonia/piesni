  <properties>
    <titles>
      <title>Ty jesteś chlebem żywym</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ty jesteś Chlebem Żywym<br/>Kto Cię spożywa nie umrze<br/>Kto w Ciebie uwierzy<br/>Nie będzie już pragnął na wieki</lines>
    </verse>
  </lyrics>
