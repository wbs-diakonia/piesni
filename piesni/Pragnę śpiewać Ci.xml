<?xml version='1.0' encoding='UTF-8'?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:47">
  <properties>
    <titles>
      <title>Pragnę śpiewać Ci</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Pragnę śpiewać Ci najpiękniejszą pieśń<br/>Z aniołami, tak pragnę śpiewać Ci<br/><br/>Święty, święty, święty jest Pan, Zastępów Pan<br/><br/>Cała ziemia jest pełna Jego chwały</lines>
    </verse>
  </lyrics>
</song>
