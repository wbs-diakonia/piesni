  <properties>
    <titles>
      <title>Oto Boży Baranek</title>
    </titles>
    <authors>
      <author>abc</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Oto Boży Baranek swym Ciałem karmi nas,<br/>Poi Krwią pełną Boskiej słodyczy,<br/>Kto spożywa to Ciało i pije Jego Krew<br/>W domu Ojca zamieszka na wieki.</lines>
    </verse>
  </lyrics>
</song>
