<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:40">
  <properties>
    <titles>
      <title>Ja czekam Cię</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ja czekam Cię, Panie mój do mnie przyjdź.<br/>I miłość daj, łaskę zlej, naucz żyć.<br/>A kiedy już będziesz mój siłę daj,<br/>abym był Twój, Panie mój, Ty i ja.</lines>
    </verse>
  </lyrics>
</song>
