  <properties>
    <titles>
      <title>Pan jest mocą swojego ludu</title>
    </titles>
    <authors>
      <author>abc</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Pan jest mocą swojego ludu.<br/>Pieśnią moją jest Pan.<br/>Moja tarcza i moja moc,<br/>On jest mym Bogiem, Nie jestem sam.<br/>W Nim moja siła, Nie jestem sam.<br/></lines>
    </verse>
  </lyrics>
