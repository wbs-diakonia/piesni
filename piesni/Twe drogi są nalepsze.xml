<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8" createdIn="OpenLP 3.1.7" modifiedIn="OpenLP 3.1.7" modifiedDate="2021-01-16T18:02:50">
  <properties>
    <titles>
      <title>Twe drogi są nalepsze</title>
    </titles>
    <authors>
      <author>a</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Twe drogi są nalepsze<br/>Najlepsze dla mnie są<br/>Ty, Panie, wiesz najlepiej,<br/>Co dla mnie dobre jest<br/><br/>I zawsze troszczysz się,<br/>Bo bardzo kochasz mnie /x2</lines>
    </verse>
  </lyrics>
</song>
